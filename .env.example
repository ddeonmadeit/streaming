# ─────────────────────────────────────────────────────────────
#  Copy this file to ".env" and fill in your values.
#      cp .env.example .env  &&  nano .env
# ─────────────────────────────────────────────────────────────

# Password your phone uses to publish (make up something strong, no spaces/colons).
PUBLISH_PASS=change-me-to-a-long-secret

# ── Platform ingest URLs + keys (paste from each dashboard) ──
# Each FULL_URL is the server URL WITH the stream key appended.

# Twitch: server is fixed; append your key. Get key: dashboard.twitch.tv → Settings → Stream
TWITCH_URL=rtmp://live.twitch.tv/app/YOUR_TWITCH_STREAM_KEY

# Kick: copy the full "Stream URL" + "Stream Key" from kick.com creator dashboard.
# Kick uses rtmps. It looks like: rtmps://xxxx.global-contribute.live-video.net/app/YOUR_KICK_KEY
KICK_URL=rtmps://YOUR_KICK_INGEST_HOST/app/YOUR_KICK_STREAM_KEY

# TikTok: from TikTok LIVE (needs LIVE + third-party/RTMP access). Server URL + key.
# Looks like: rtmp://xxxx.push.tiktokcdn.com/live/YOUR_TIKTOK_KEY
TIKTOK_URL=rtmp://YOUR_TIKTOK_INGEST_HOST/live/YOUR_TIKTOK_STREAM_KEY

# ── Output encode settings (720p60 defaults) ──
VIDEO_BITRATE=6000k
MAXRATE=6000k
BUFSIZE=12000k
AUDIO_BITRATE=160k
WIDTH=1280
HEIGHT=720
FPS=60
# GOP = FPS * 2  (2-second keyframe interval, required by Twitch)
GOP=120
